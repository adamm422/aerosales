# =====================================
# SZABLON ZMIENNYCH ŚRODOWISKOWYCH
# =====================================
# Skopiuj ten plik jako .env i wypełnij właściwymi wartościami
# NIGDY nie commituj pliku .env do repozytorium!

# =====================================
# API KEYS - BACKEND ONLY
# =====================================
# Te klucze są używane TYLKO po stronie serwera (API Routes/Edge Functions)
# NIGDY nie dodawaj prefiksu VITE_ lub NEXT_PUBLIC_ do tych zmiennych!

# OpenAI API
OPENAI_API_KEY=sk-your-openai-key-here

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Supabase
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co

# Database
DATABASE_URL=postgresql://user:password@host:port/database

# Inne API
SENDGRID_API_KEY=SG.your-sendgrid-key
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret

# =====================================
# APP CONFIGURATION
# =====================================
NODE_ENV=development
PORT=3000

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# =====================================
# FRONTEND (jeśli potrzebne - mogą mieć prefiks VITE_)
# =====================================
# TYLKO zmienne, które MUSZĄ być dostępne w przeglądarce
# VITE_PUBLIC_API_URL=http://localhost:3000/api